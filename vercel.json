{
  "installCommand": "npm install",
  "buildCommand": "npm run server:build",
  "outputDirectory": ".",
  "functions": {
    "dist/http.js": {
      "runtime": "node"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
