{
  "installCommand": "npm install",
  "buildCommand": "npm run server:build && mkdir dist/api && mv dist/http.js dist/api/http.js",
  "outputDirectory": "dist",
  "builds": [
    {
      "src": "api/http.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/http.js",
      "headers": { "Access-Control-Allow-Origin": "*" }
    }
  ]
}
