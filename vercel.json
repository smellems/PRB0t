{
  "installCommand": "npm install",
  "buildCommand": "npm run server:build && mkdir dist/api && mv dist/http.js dist/api/http.js",
  "outputDirectory": "dist",
  "functions": {
    "api/http.js": {
      "maxDuration": "30"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
