{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run server:build",
  "outputDirectory": ".",
  "builds": [
    {
      "src": "http.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "http.js",
      "headers": { "Access-Control-Allow-Origin": "*" }
    }
  ]
}
